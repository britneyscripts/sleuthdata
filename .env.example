# ------------------------------------------------------------------------------
# Query-Driven Job Crawler - Environment Configuration Example
# Copy this file to .env and adjust configurations as needed.
# ------------------------------------------------------------------------------

# Database Connection URL
# For PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_crawler
# For local SQLite testing fallback:
# DATABASE_URL=sqlite:///./local_jobs.db

# Postgres credentials used by docker-compose.yml (only relevant for Docker deployments)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=job_crawler

# Redis Connection URL
REDIS_URL=redis://localhost:6379/0

# Optional: Gemini API Key for automatic skill and metadata extraction
# GEMINI_API_KEY=AIzaSy...

# Required in production: API key clients must send via the x-api-key header
# to hit POST /search-queries and POST /search-queries/{id}/crawl.
# If unset and ENV=development, a fixed dev fallback key is used instead (see core/security.py).
API_KEY=change_me_in_prod
